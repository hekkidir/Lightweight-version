# Deployment settings — copy to .env and adjust per environment.
# These override runtime behavior WITHOUT editing tracked files. Analytical knobs
# (stage thresholds, rotation windows) stay in config.ini instead.
#
# .env is git-ignored; never commit real secrets.

# ── Server ──
SCREENER_HOST=0.0.0.0
SCREENER_PORT=8000

# ── Data location (mount a volume here on a server) ──
# SCREENER_DATA_DIR=/var/lib/screener/data

# ── Logging: DEBUG | INFO | WARNING | ERROR ──
SCREENER_LOG_LEVEL=INFO

# ── Live pre/regular-market snapshot. Set false on a server that only wants
#    end-of-day bars (avoids intraday yfinance calls). ──
SCREENER_LIVE_SNAPSHOT=true

# ── CORS: comma-separated origins allowed to call the API (empty = same-origin only) ──
# SCREENER_CORS_ORIGINS=https://dashboard.example.com

# ── Auth: if set, API requests must send  Authorization: Bearer <token>  (empty = open) ──
# SCREENER_AUTH_TOKEN=

# ── Failure alerts: webhook (Slack/Discord/generic) notified if the pipeline fails ──
# SCREENER_ALERT_WEBHOOK=https://hooks.slack.com/services/...
